        android:label="@string/app_name"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar">

        <activity
            android:name=".MainActivity"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".AddActivity" android:label="@string/title_activity_add" />
        <activity android:name=".SubActivity" android:label="@string/title_activity_sub" />
        <activity android:name=".MulActivity" android:label="@string/title_activity_mul" />
        <activity android:name=".DivActivity" android:label="@string/title_activity_div" />

    </application>
</manifest>
