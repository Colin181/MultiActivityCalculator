<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#FAFAFA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/select_operation"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="32dp" />

    <Button android:id="@+id/btnAdd" android:layout_width="match_parent" android:layout_height="56dp"
        android:text="@string/addition" android:textSize="18sp" android:layout_marginBottom="12dp" android:backgroundTint="#4CAF50" />
    <Button android:id="@+id/btnSub" android:layout_width="match_parent" android:layout_height="56dp"
        android:text="@string/subtraction" android:textSize="18sp" android:layout_marginBottom="12dp" android:backgroundTint="#2196F3" />
    <Button android:id="@+id/btnMul" android:layout_width="match_parent" android:layout_height="56dp"
        android:text="@string/multiplication" android:textSize="18sp" android:layout_marginBottom="12dp" android:backgroundTint="#FF9800" />
    <Button android:id="@+id/btnDiv" android:layout_width="match_parent" android:layout_height="56dp"
        android:text="@string/division" android:textSize="18sp" android:backgroundTint="#F44336" />
</LinearLayout>
